# For Docker Compose deployment on Raspberry Pi. For local development use sync-server/.env.example instead.

# Copy to .env before first run.

# Network bind. Keep 127.0.0.1 when using Tailscale/WireGuard on host.
SYNC_BIND_IP=127.0.0.1
SYNC_PORT=8787

# Postgres
POSTGRES_DB=securepass_sync
POSTGRES_USER=securepass
POSTGRES_PASSWORD=CHANGE_THIS_TO_A_LONG_RANDOM_PASSWORD
POSTGRES_BIND_IP=127.0.0.1
POSTGRES_PORT=5432

# API secrets (minimum 32 chars each)
JWT_ACCESS_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_SECRET_MIN_32_CHARS
MFA_ISSUER=SecurePass

# Bootstrap token — used once to create the very first account (only works when 0 users exist)
BOOTSTRAP_TOKEN=CHANGE_THIS_TO_A_LONG_RANDOM_BOOTSTRAP_TOKEN

# Token and rate-limit tuning
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
# Stricter limit for auth endpoints (login, register, refresh) - 20 attempts per 15 min per IP
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20

# Set to true when behind a reverse proxy or ngrok so rate limiting uses the real client IP
TRUST_PROXY=true

# ngrok tunnel — required for internet access
# Get your authtoken from https://dashboard.ngrok.com/authtokens
NGROK_AUTHTOKEN=CHANGE_THIS_TO_YOUR_NGROK_AUTHTOKEN
# Your static domain from https://dashboard.ngrok.com/domains
NGROK_DOMAIN=your-static-domain.ngrok-free.app

# Public URL used for invite links — set to your ngrok domain
PUBLIC_BASE_URL=https://your-static-domain.ngrok-free.app

# Set to false to block all new registrations entirely.
# When true, /register requires a valid per-user invite token.
ALLOW_REGISTRATION=true
# Invite management policy:
# - admin: only admin users (bootstrap owner) can create/list/revoke invites
# - any: any authenticated user can manage invites
INVITE_CREATION_POLICY=admin
